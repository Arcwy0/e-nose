# ─────────────────────────────────────────────────────────────────────────────
# enose — environment template
#
# Copy to `.env` (which is gitignored) and edit in place. The server reads
# these via os.environ at startup; `.env` itself is NOT auto-loaded by the
# server today — `source .env` before launching, or use a tool like
# `direnv` / `dotenv`. Docker containers pick them up via `--env-file .env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Classifier backend ───────────────────────────────────────────────────────
# One of: balanced_rf (default) | xgb
ENOSE_CLASSIFIER=balanced_rf

# ── Vision / Florence-2 ──────────────────────────────────────────────────────
# Set to 1 to skip loading Florence-2 (smell-only server, no GPU needed).
# Unset or 0 for full multimodal mode — requires model weights at
# model/Florence-2-Large/ (see docs/SETUP.md for how to fetch them).
ENOSE_NO_VLM=1

# ── Server bind ──────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── HuggingFace (only needed when downloading Florence-2 on a gated mirror) ──
# Create a read-only token at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── tuna.am tunnel (server host, optional) ───────────────────────────────────
# Used by ops scripts only; the runtime code does NOT read these.